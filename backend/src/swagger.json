        ]
      }
    },
    "/messages/direct": {
      "post": {
        "summary": "SendDirectMessage",
        "responses": {},
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              },
              "example": "{\r\n    \"recipientId\": \"6a0ef5ebd100e6b5ac786f6d\", // id của user nhận\r\n    \"content\": \"First message\"\r\n}"
            }
          }
        }
      }
    },
    "/conversations": {
      "post": {
        "summary": "CreateConversation",
        "responses": {},
        "security": [
          {
