      "post": {
        "summary": "SendFriendRequest",
        "responses": {},
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "to": {
                    "type": "string"
                  },
                  "message": {
                    "type": "string"
                  }
                }
              },
              "example": {
                "to": "6a11afdce824ce3aaf259b8b",
                "message": "hello user4"
              }
            }
          }
        }
      },
      "get": {
        "summary": "GetFriendRequest",
