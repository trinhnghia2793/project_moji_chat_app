  "paths": {
    "/auth/signup": {
      "post": {
        "summary": "SignUp",
        "responses": {},
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "username": {
                    "type": "string"
                  },
                  "password": {
                    "type": "string",
                    "format": "color"
                  },
                  "email": {
                    "type": "string",
                    "format": "email"
                  },
                  "firstName": {
                    "type": "string"
                  },
                  "lastName": {
                    "type": "string"
                  }
                }
              },
              "example": {
                "username": "user4",
                "password": "123123",
                "email": "user4@gmail.com",
                "firstName": "User",
                "lastName": "Four"
              }
            }
          }
        }
      }
    },
    "/auth/signin": {
      "post": {
        "summary": "SignIn",
        "description": "Login với username và passowrd. Trả về accessToken trong res và refreshToken trong cookie",
        "tags": ["Authentication"],
        "responses": {
          "200": {
            "description": "Login successful",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "User Two User logged in!"
                    },
                    "accessToken": {
                      "type": "string",
                      "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
                    }
                  }
                }
              }
            }
          },
          "400": { "description": "Invalid input" },
          "401": { "description": "Unauthorized" },
          "500": { "description": "Internal server error" }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "username": {
                    "type": "string"
                  },
                  "password": {
                    "type": "string",
                    "format": "color"
                  },
                  "required": ["username", "password"]
                }
              },
              "example": {
                "username": "user2",
                "password": "123456"
              }
            }
          }
        }
      }
    },
    "/auth/signout": {
      "post": {
        "summary": "SignOut",
        "tags": ["Authentication"],
        "responses": {
          "200": { "description": "Success" },
          "500": { "description": "Internal server error" }
        },
        "security": [
          {
            "BearerAuth": []
          }
        ]
      }
    },
    "/auth/refresh": {
      "post": {
        "summary": "RefreshToken",
        "responses": {}
      }
    },
    "/users/me": {
      "get": {
        "summary": "AuthMe",
        "responses": {},
        "security": [
          {
            "BearerAuth": []
          }
        ]
      }
    },
