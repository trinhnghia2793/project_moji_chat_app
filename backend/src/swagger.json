          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              },
              "example": "{\r\n    \"type\": \"group\",\r\n    \"name\": \"Nhóm ABC (2-3) (chuẩn)\",\r\n    \"memberIds\": [\r\n        \"6a0ef5ebd100e6b5ac786f6d\"\r\n        // \"6a11afdce824ce3aaf259b8b\"\r\n    ]\r\n}"
            }
          }
        }
      },
      "get": {
        "summary": "GetConversations",
