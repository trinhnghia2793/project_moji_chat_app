{
  "openapi": "3.0.0",
  "info": {
    "title": "Moji_chat_app",
    "version": "1.0.0",
    "description": ""
  },
  "servers": [
    {
      "url": "http://localhost:5001/api"
    },
    {
      "url": ""
    }
